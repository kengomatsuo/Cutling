<plist version="1.0">
<dict>
	<!-- Direct-download (Developer ID) macOS build only. These Sparkle keys
	     live here, NOT in Cutling/Info.plist, so the App Store builds (iOS +
	     macOS, from the `Cutling` target) never carry a self-updater. The
	     `Cutling (Direct)` target is the only one that links Sparkle. -->
	<key>SUFeedURL</key>
	<string>https://kengomatsuo.github.io/Cutling/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>ZyT4/ezVd83f4Q2V8xPNKbqdaHmgpK9twWZt8gWyEDk=</string>
	<!-- Opt-in: don't auto-check until the user turns it on in onboarding or
	     Settings. This also suppresses Sparkle's own second-launch permission
	     prompt, since Cutling presents the choice in its Welcome flow instead. -->
	<key>SUEnableAutomaticChecks</key>
	<false/>
	<key>SUEnableInstallerLauncherService</key>
	<true/>
	<key>SUEnableDownloaderService</key>
	<true/>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
