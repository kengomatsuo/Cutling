"Edit the text, then tap Back. Your changes save automatically." = "Edit teksnya, lalu ketuk Kembali. Perubahan Anda tersimpan secara otomatis.";
"Edit anything, then go back to save." = "Edit apa saja, lalu kembali untuk menyimpan.";
"Edit the text or anything else you like." = "Edit teksnya atau apa pun yang Anda suka.";
"Tap a deleted cutling to bring it back." = "Ketuk cutling yang dihapus untuk mengembalikannya.";
"Nice! Your cutling is saved." = "Bagus! Cutling kamu tersimpan.";
"Tap the ⋯ button on a card to open and edit it." = "Ketuk tombol ⋯ pada kartu untuk membukanya dan mengeditnya.";
"To delete, open a cutling with the ⋯ button." = "Untuk menghapus, buka cutling dengan tombol ⋯.";
"Scroll down and tap Delete Cutling to remove it." = "Gulir ke bawah dan ketuk Hapus Cutling untuk menghapusnya.";
"Skip Tutorial" = "Lewati Tutorial";
"Leave Tutorial?" = "Keluar dari Tutorial?";
"Leave" = "Keluar";
"Continue Tutorial" = "Lanjutkan Tutorial";
"You can restart it anytime from How to Use Cutling in the keyboard settings." = "Anda dapat memulainya ulang kapan saja dari Cara Menggunakan Cutling di pengaturan keyboard.";

/* MARK: - TipKit */
"Saved cutlings" = "Cutling tersimpan";
"Your pinned snippets live here, ready to copy with one click." = "Potongan yang Anda sematkan ada di sini, siap disalin sekali klik.";
"Recent clipboard" = "Papan klip terkini";
"Everything you copy lands here. Right-click any row to save it as a cutling." = "Semua yang Anda salin mendarat di sini. Klik kanan baris untuk menyimpannya sebagai cutling.";
"Wipe the list" = "Kosongkan daftar";
"Empties your recent clipboard. Saved cutlings stay put." = "Mengosongkan papan klip terkini Anda. Cutling tersimpan tetap ada.";
"Rebind the hotkey, toggle clipboard capture, and manage iCloud sync." = "Atur ulang pintasan, alihkan perekaman papan klip, dan kelola sinkronisasi iCloud.";
"Undo deletes" = "Urungkan penghapusan";
"Deleted cutlings stay here for 30 days. Restore them or empty for good." = "Cutling yang dihapus tetap di sini selama 30 hari. Pulihkan atau kosongkan secara permanen.";
"Tap here to select multiple cutlings, reorder them, or restore recently deleted ones." = "Ketuk di sini untuk memilih beberapa cutling, menyusun ulang, atau memulihkan yang baru dihapus.";
"Long-press a cutling" = "Tekan lama pada cutling";
"Hold any card for quick actions: copy, edit, share, or delete." = "Tahan kartu mana pun untuk tindakan cepat: salin, edit, bagikan, atau hapus.";
"Drag to select" = "Seret untuk memilih";
"Swipe across cards to select a range. Swipe back over them to deselect." = "Geser pada kartu untuk memilih rentang. Geser kembali untuk membatalkan pilihan.";
"Smart field matching" = "Pencocokan bidang cerdas";
"Cutling spots email, URL, phone, and address fields, then floats matching snippets to the top of the keyboard." = "Cutling mengenali bidang email, URL, telepon, dan alamat, lalu menaikkan potongan yang sesuai ke bagian atas keyboard.";
"Create a new cutling" = "Buat cutling baru";
"Save text or image snippets you'll reuse from any app." = "Simpan potongan teks atau gambar yang akan Anda gunakan kembali dari aplikasi mana pun.";

/* MARK: - Welcome Window (macOS first launch) */
"Welcome to Cutling" = "Selamat Datang di Cutling";
"Your clipboard, organised." = "Papan klip Anda, tertata rapi.";
"Save the snippets, images, and links you reuse. Capture everything you copy. Paste anywhere with one shortcut." = "Simpan potongan teks, gambar, dan tautan yang sering Anda gunakan. Tangkap semua yang Anda salin. Tempel di mana saja dengan satu pintasan.";
"Look up. Cutling lives in your menu bar" = "Lihat ke atas. Cutling ada di bilah menu Anda";
"The clipboard icon at the top of your screen opens Cutling any time. Click it to see your saved cutlings and recent clipboard history." = "Ikon papan klip di bagian atas layar Anda membuka Cutling kapan saja. Klik untuk melihat cutling yang tersimpan dan riwayat papan klip terbaru.";
"Summon Cutling from anywhere" = "Panggil Cutling dari mana saja";
"Press ⌘⇧V from any app to open a floating picker at your cursor. Pick a cutling and it's ready to paste, no menu bar trip required." = "Tekan ⌘⇧V dari aplikasi mana pun untuk membuka pemilih melayang di posisi kursor Anda. Pilih sebuah cutling dan langsung siap ditempel, tanpa perlu ke bilah menu.";
"Rebind it later in Settings → Hotkey." = "Anda dapat mengubah pintasan nanti di Pengaturan → Pintasan.";
"Almost there" = "Hampir selesai";
"You're all set" = "Semua sudah siap";
"Two quick permissions so Cutling can work the way you'd expect. You can change either later in Settings." = "Dua izin singkat agar Cutling dapat bekerja sesuai harapan Anda. Anda dapat mengubah keduanya nanti di Pengaturan.";
"Launch at login" = "Jalankan saat masuk";
"Open Cutling automatically when you sign in." = "Buka Cutling secara otomatis saat Anda masuk.";
"Accessibility access" = "Akses Aksesibilitas";
"Granted. Cutling can paste directly into other apps." = "Diberikan. Cutling dapat menempel langsung ke aplikasi lain.";
"Lets Cutling paste a cutling straight into the app you were using." = "Memungkinkan Cutling menempel sebuah cutling langsung ke aplikasi yang sedang Anda gunakan.";
"Grant" = "Berikan";
"You can skip Accessibility and grant it later from Settings → Paste." = "Anda dapat melewati Aksesibilitas dan memberikannya nanti dari Pengaturan → Tempel.";


/* MARK: - Image Saving (macOS) */
"Save as File…" = "Simpan sebagai berkas…";
"Image Saving" = "Penyimpanan gambar";
"When saving images" = "Saat menyimpan gambar";
"Ask each time" = "Tanyakan setiap kali";
"Save to folder" = "Simpan ke folder";
"Folder" = "Folder";
"Change Folder…" = "Ubah folder…";
"Choose how the “Save as File” action works for image cutlings. With “Save to folder”, images go straight into the folder you pick with a unique filename, no prompt." = "Pilih bagaimana tindakan “Simpan sebagai berkas” bekerja untuk cutling gambar. Dengan “Simpan ke folder”, gambar langsung tersimpan di folder yang Anda pilih dengan nama berkas unik, tanpa pertanyaan.";
"Choose" = "Pilih";
"Choose Image Folder" = "Pilih folder gambar";
"Pick a folder where Cutling will save image cutlings." = "Pilih folder tempat Cutling akan menyimpan cutling gambar.";
"Preview" = "Pratinjau";


/* MARK: - Newly added keys */
"Saved" = "Tersimpan";
"History" = "Riwayat";
"No saved cutlings yet" = "Belum ada cutling tersimpan";
"Copy something to see it here" = "Salin sesuatu untuk melihatnya di sini";
"Clipboard history is off. Enable it in Settings." = "Riwayat papan klip nonaktif. Aktifkan di Pengaturan.";
"Spotlight" = "Spotlight";
"Include in Spotlight Search" = "Sertakan dalam pencarian Spotlight";
"Make your cutlings searchable from Spotlight. Sensitive content (credit cards, API keys, JWT tokens, seed phrases, private keys) is never indexed." = "Buat cutling Anda dapat dicari dari Spotlight. Konten sensitif (kartu kredit, kunci API, token JWT, frasa benih, kunci privat) tidak pernah diindeks.";
"Copy Cutling" = "Salin Cutling";
"Copy a cutling's contents to the clipboard." = "Menyalin konten cutling ke papan klip.";
"Use these phrases with Siri or browse all Cutling shortcuts in the Shortcuts app." = "Gunakan frasa ini dengan Siri atau jelajahi semua pintasan Cutling di aplikasi Pintasan.";
"Copied \"%@\"" = "“%@” disalin";

/* MARK: - Paste Settings (macOS) - Direct Paste opt-in */
"Paste directly into other apps" = "Tempel langsung ke aplikasi lain";
"When on, picking a cutling from the hotkey-summoned picker sends a single ⌘V keystroke into the app that was frontmost, so the cutling is pasted at the cursor. Off by default. When off, Cutling copies to the clipboard and you paste manually with ⌘V." = "Saat aktif, memilih sebuah Cutling dari pemilih yang dimunculkan pintasan akan mengirim satu ketukan ⌘V ke aplikasi yang sebelumnya berada di depan, sehingga Cutling tertempel di posisi kursor. Mati secara baku. Saat mati, Cutling menyalin ke papan klip dan kamu menempelnya secara manual dengan ⌘V.";
"Permission" = "Izin";
"Cutling uses Accessibility access only to send the ⌘V keystroke to the previously focused app after you pick a cutling. It does not read other apps' UI or control your computer." = "Cutling menggunakan Akses Aksesibilitas hanya untuk mengirim ketukan ⌘V ke aplikasi yang sebelumnya berfokus setelah kamu memilih sebuah Cutling. Aplikasi ini tidak membaca UI aplikasi lain atau mengontrol komputermu.";
"Direct Paste" = "Tempel Langsung";
"Direct paste needs Accessibility access." = "Tempel langsung memerlukan Akses Aksesibilitas.";

/* MARK: - Updates (macOS, direct-download build) */
"Updates" = "Pembaruan";
"Check for Updates…" = "Periksa Pembaruan…";
"Check for updates automatically" = "Periksa pembaruan secara otomatis";
"Cutling can update itself to new versions. Turn on automatic checks, or check for updates manually any time." = "Cutling dapat memperbarui dirinya ke versi baru. Aktifkan pemeriksaan otomatis, atau periksa pembaruan secara manual kapan saja.";
"Automatic updates" = "Pembaruan otomatis";
"Let Cutling check for and install new versions on its own." = "Biarkan Cutling memeriksa dan memasang versi baru sendiri.";
"A few quick settings so Cutling can work the way you'd expect. You can change any of these later in Settings." = "Beberapa pengaturan singkat agar Cutling dapat bekerja sesuai harapan Anda. Anda dapat mengubah semuanya nanti di Pengaturan.";
