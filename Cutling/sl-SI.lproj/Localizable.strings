"Drag to select" = "Povleci za izbiro";
"Swipe across cards to select a range. Swipe back over them to deselect." = "Podrsaj čez kartice, da izbereš obseg. Podrsaj nazaj, da prekličeš izbor.";
"Smart field matching" = "Pametno prepoznavanje polj";
"Cutling spots email, URL, phone, and address fields, then floats matching snippets to the top of the keyboard." = "Cutling zazna polja za e-pošto, URL, telefon in naslov, ter dvigne ustrezne odlomke na vrh tipkovnice.";
"Create a new cutling" = "Ustvari nov cutling";
"Save text or image snippets you'll reuse from any app." = "Shrani odlomke besedila ali slik, ki jih boš znova uporabljal iz katere koli aplikacije.";

/* MARK: - Welcome Window (macOS first launch) */
"Welcome to Cutling" = "Dobrodošli v Cutlingu";
"Your clipboard, organised." = "Vaše odložišče, urejeno.";
"Save the snippets, images, and links you reuse. Capture everything you copy. Paste anywhere with one shortcut." = "Shranjujte odlomke, slike in povezave, ki jih ponovno uporabljate. Zajemajte vse, kar kopirate. Prilepite kamor koli z eno bližnjico.";
"Look up. Cutling lives in your menu bar" = "Poglejte navzgor. Cutling živi v vaši menijski vrstici";
"The clipboard icon at the top of your screen opens Cutling any time. Click it to see your saved cutlings and recent clipboard history." = "Ikona odložišča na vrhu zaslona kadar koli odpre Cutling. Kliknite jo, da vidite shranjene cutlinge in nedavno zgodovino odložišča.";
"Summon Cutling from anywhere" = "Prikličite Cutling od koder koli";
"Press ⌘⇧V from any app to open a floating picker at your cursor. Pick a cutling and it's ready to paste, no menu bar trip required." = "Pritisnite ⌘⇧V v kateri koli aplikaciji, da odprete plavajoči izbirnik pri kazalcu. Izberite cutling in pripravljen je za lepljenje, brez obiska menijske vrstice.";
"Rebind it later in Settings → Hotkey." = "Bližnjico lahko spremenite kasneje v Nastavitve → Bližnjica.";
"Almost there" = "Skoraj tam";
"You're all set" = "Vse je pripravljeno";
"Two quick permissions so Cutling can work the way you'd expect. You can change either later in Settings." = "Dve hitri dovoljenji, da bo Cutling deloval, kot pričakujete. Obe lahko kasneje spremenite v Nastavitvah.";
"Launch at login" = "Zaženi ob prijavi";
"Open Cutling automatically when you sign in." = "Samodejno odpri Cutling ob prijavi.";
"Accessibility access" = "Dostop do dostopnosti";
"Granted. Cutling can paste directly into other apps." = "Odobreno. Cutling lahko lepi neposredno v druge aplikacije.";
"Lets Cutling paste a cutling straight into the app you were using." = "Omogoča Cutlingu, da prilepi cutling neposredno v aplikacijo, ki ste jo uporabljali.";
"Grant" = "Odobri";
"You can skip Accessibility and grant it later from Settings → Paste." = "Dostopnost lahko preskočite in jo odobrite kasneje v Nastavitve → Lepljenje.";


/* MARK: - Image Saving (macOS) */
"Save as File…" = "Shrani kot datoteko…";
"Image Saving" = "Shranjevanje slik";
"When saving images" = "Pri shranjevanju slik";
"Ask each time" = "Vsakič vprašaj";
"Save to folder" = "Shrani v mapo";
"Folder" = "Mapa";
"Change Folder…" = "Spremeni mapo…";
"Choose how the “Save as File” action works for image cutlings. With “Save to folder”, images go straight into the folder you pick with a unique filename, no prompt." = "Izberi, kako deluje dejanje „Shrani kot datoteko“ za slikovne Cutlinge. Z možnostjo „Shrani v mapo“ se slike samodejno shranijo v izbrano mapo z edinstvenim imenom datoteke, brez vprašanja.";
"Choose" = "Izberi";
"Choose Image Folder" = "Izberi mapo za slike";
"Pick a folder where Cutling will save image cutlings." = "Izberi mapo, kamor bo Cutling shranjeval slikovne Cutlinge.";
"Preview" = "Predogled";


