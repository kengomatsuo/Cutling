/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "Išsaugoti iškarpinę į ${applicationName}";
"Save to ${applicationName}" = "Išsaugoti į ${applicationName}";
"Add clipboard to ${applicationName}" = "Pridėti iškarpinę į ${applicationName}";
"Clip with ${applicationName}" = "Iškirpti su ${applicationName}";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "Kopijuoti ${target} iš ${applicationName}";
"Paste ${target} with ${applicationName}" = "Įklijuoti ${target} su ${applicationName}";
"Get ${target} from ${applicationName}" = "Gauti ${target} iš ${applicationName}";

/* 3. Save Text */
"Save text to ${applicationName}" = "Išsaugoti tekstą į ${applicationName}";
"Save text with ${applicationName}" = "Išsaugoti tekstą su ${applicationName}";
"Add text to ${applicationName}" = "Pridėti tekstą į ${applicationName}";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "Gauti ${target} tekstą iš ${applicationName}";
"Read ${target} from ${applicationName}" = "Skaityti ${target} iš ${applicationName}";

/* 5. Latest Cutling */
"Get latest from ${applicationName}" = "Gauti naujausią iš ${applicationName}";
"Latest ${applicationName}" = "Naujausias ${applicationName}";
"Most recent ${applicationName}" = "Vėliausias ${applicationName}";

/* 6. New Text Cutling */
"New text in ${applicationName}" = "Naujas tekstas ${applicationName}";
"Create text in ${applicationName}" = "Sukurti tekstą ${applicationName}";
"New text cutling with ${applicationName}" = "Naujas teksto cutling su ${applicationName}";

/* 7. New Image Cutling */
"New image in ${applicationName}" = "Naujas vaizdas ${applicationName}";
"Create image in ${applicationName}" = "Sukurti vaizdą ${applicationName}";
"New image cutling with ${applicationName}" = "Naujas vaizdo cutling su ${applicationName}";

/* 8. Save Image */
"Save image to ${applicationName}" = "Išsaugoti vaizdą į ${applicationName}";
"Save image with ${applicationName}" = "Išsaugoti vaizdą su ${applicationName}";
"Add image to ${applicationName}" = "Pridėti vaizdą į ${applicationName}";

/* 9. Search Cutlings */
"Search ${applicationName}" = "Ieškoti ${applicationName}";
"Find in ${applicationName}" = "Rasti ${applicationName}";
"Search in ${applicationName}" = "Ieškoti ${applicationName}";

/* 10. Open Cutling */
"Open ${applicationName}" = "Atverti ${applicationName}";
"Launch ${applicationName}" = "Paleisti ${applicationName}";
