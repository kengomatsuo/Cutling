/* MARK: - Paste Settings (macOS) - Direct Paste opt-in */
"Paste directly into other apps" = "Direkt in andere Apps einfügen";
"When on, picking a cutling from the hotkey-summoned picker sends a single ⌘V keystroke into the app that was frontmost, so the cutling is pasted at the cursor. Off by default. When off, Cutling copies to the clipboard and you paste manually with ⌘V." = "Ist diese Option aktiviert, sendet das Auswählen eines Cutlings im per Tastenkürzel aufgerufenen Picker ein einzelnes ⌘V an die zuvor aktive App, sodass der Cutling an der Cursorposition eingefügt wird. Standardmäßig deaktiviert. Ist sie deaktiviert, kopiert Cutling in die Zwischenablage und du fügst manuell mit ⌘V ein.";
"Permission" = "Berechtigung";
"Cutling uses Accessibility access only to send the ⌘V keystroke to the previously focused app after you pick a cutling. It does not read other apps' UI or control your computer." = "Cutling nutzt den Bedienungshilfen-Zugriff ausschließlich, um nach deiner Auswahl eines Cutlings die Tastenkombination ⌘V an die zuletzt fokussierte App zu senden. Es liest die Benutzeroberfläche anderer Apps nicht aus und steuert deinen Computer nicht.";
"Direct Paste" = "Direktes Einfügen";
"Direct paste needs Accessibility access." = "Direktes Einfügen benötigt Bedienungshilfen-Zugriff.";

/* MARK: - Interactive Tutorial (iOS walkthrough) */
"How to Use Cutling" = "So verwendest du Cutling";
"Tap the ⋯ button on a card to open and edit it." = "Tippe auf die ⋯ Taste einer Karte, um sie zu öffnen und zu bearbeiten.";
"To delete, open a cutling with the ⋯ button." = "Zum Löschen öffne einen Cutling mit der ⋯ Taste.";
"Scroll down and tap Delete Cutling to remove it." = "Scrolle nach unten und tippe auf Cutling löschen, um ihn zu entfernen.";
"Create a cutling" = "Cutling erstellen";
"Tap + to save text or an image you reuse often." = "Tippe auf +, um Text oder ein Bild zu sichern, das du oft wiederverwendest.";
"Edit a cutling" = "Cutling bearbeiten";
"Touch and hold any card, then choose Edit to change it." = "Halte eine beliebige Karte gedrückt und wähle dann Bearbeiten, um sie zu ändern.";
"Delete a cutling" = "Cutling löschen";
"Touch and hold a card, then choose Delete to remove it." = "Halte eine Karte gedrückt und wähle dann Löschen, um sie zu entfernen.";
"Recover a cutling" = "Cutling wiederherstellen";
"Open the More menu, then Recently Deleted, to restore anything you removed." = "Öffne das Menü Weitere Optionen und dann Zuletzt gelöscht, um Entferntes wiederherzustellen.";
"Touch and hold a deleted cutling, then tap Recover." = "Halte einen gelöschten Cutling gedrückt und tippe dann auf Wiederherstellen.";
"Recovered! Your cutling is back." = "Wiederhergestellt! Dein Cutling ist zurück.";
"Tap + to start a new text cutling." = "Tippe auf +, um einen neuen Text-Cutling zu beginnen.";
"Give your cutling a name." = "Gib deinem Cutling einen Namen.";
"Now type the text you want to save." = "Gib jetzt den Text ein, den du sichern möchtest.";
"Tap here to save your cutling." = "Tippe hier, um deinen Cutling zu sichern.";
"Edit the text, then tap here to save." = "Bearbeite den Text und tippe dann hier, um zu sichern.";
"Edit the text, then tap Back. Your changes save automatically." = "Bearbeite den Text und tippe dann auf Zurück. Deine Änderungen werden automatisch gesichert.";
"Edit anything, then go back to save." = "Bearbeite, was du möchtest, und geh dann zurück, um zu sichern.";
"Edit the text or anything else you like." = "Bearbeite den Text oder was du sonst noch möchtest.";
"Tap a deleted cutling to bring it back." = "Tippe auf einen gelöschten Cutling, um ihn wiederherzustellen.";
"Skip Tutorial" = "Tutorial überspringen";
"Nice! Your cutling is saved." = "Super! Dein Cutling ist gesichert.";
