"Saved" = "Saglabātie";
"History" = "Vēsture";
"No saved cutlings yet" = "Vēl nav saglabātu cutling vienību";
"Copy something to see it here" = "Nokopē kaut ko, lai redzētu šeit";
"Clipboard history is off. Enable it in Settings." = "Starpliktuves vēsture ir izslēgta. Ieslēdz to Iestatījumos.";
"Spotlight" = "Spotlight";
"Include in Spotlight Search" = "Iekļaut Spotlight meklēšanā";
"Make your cutlings searchable from Spotlight. Sensitive content (credit cards, API keys, JWT tokens, seed phrases, private keys) is never indexed." = "Padari savas cutling vienības meklējamas no Spotlight. Sensitīvs saturs (kredītkartes, API atslēgas, JWT marķieri, sākotnējās frāzes, privātās atslēgas) nekad netiek indeksēts.";
"Copy Cutling" = "Kopēt Cutling";
"Copy a cutling's contents to the clipboard." = "Iekopē cutling vienības saturu starpliktuvē.";
"Use these phrases with Siri or browse all Cutling shortcuts in the Shortcuts app." = "Lieto šīs frāzes ar Siri vai pārlūko visas Cutling īsceļas lietotnē Īsceļas.";
"Copied \"%@\"" = "„%@“ nokopēts";
