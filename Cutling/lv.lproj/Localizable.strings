"Wipe the list" = "Notīrīt sarakstu";
"Empties your recent clipboard. Saved cutlings stay put." = "Notīra tavu neseno starpliktuvi. Saglabātie cutlings paliek.";
"Rebind the hotkey, toggle clipboard capture, and manage iCloud sync." = "Maini īsinājumtaustiņu, ieslēdz/izslēdz starpliktuves uzņemšanu un pārvaldi iCloud sinhronizāciju.";
"Undo deletes" = "Atsaukt dzēšanas";
"Deleted cutlings stay here for 30 days. Restore them or empty for good." = "Dzēstie cutlings šeit paliek 30 dienas. Atjauno tos vai notīri uz visiem laikiem.";
"Tap here to select multiple cutlings, reorder them, or restore recently deleted ones." = "Pieskaries šeit, lai atlasītu vairākus cutlings, pārkārtotu tos vai atjaunotu nesen dzēstos.";
"Long-press a cutling" = "Ilgi nospied cutlingu";
"Hold any card for quick actions: copy, edit, share, or delete." = "Turi nospiestu jebkuru kartīti ātrām darbībām: kopēt, rediģēt, kopīgot vai dzēst.";
"Drag to select" = "Velc, lai atlasītu";
"Swipe across cards to select a range. Swipe back over them to deselect." = "Velc pa kartītēm, lai atlasītu diapazonu. Velc atpakaļ, lai noņemtu atlasi.";
"Smart field matching" = "Viedā lauku atpazīšana";
"Cutling spots email, URL, phone, and address fields, then floats matching snippets to the top of the keyboard." = "Cutling atpazīst e-pasta, URL, tālruņa un adreses laukus, un paceļ atbilstošos fragmentus tastatūras augšpusē.";
"Create a new cutling" = "Izveido jaunu cutlingu";
"Save text or image snippets you'll reuse from any app." = "Saglabā teksta vai attēla fragmentus, ko atkārtoti izmantosi no jebkuras lietotnes.";

/* MARK: - Welcome Window (macOS first launch) */
"Welcome to Cutling" = "Laipni lūdzam Cutling";
"Your clipboard, organised." = "Jūsu starpliktuve, sakārtota.";
"Save the snippets, images, and links you reuse. Capture everything you copy. Paste anywhere with one shortcut." = "Saglabājiet fragmentus, attēlus un saites, ko izmantojat atkārtoti. Tveriet visu, ko kopējat. Ielīmējiet jebkur ar vienu īsinājumtaustiņu.";
"Look up. Cutling lives in your menu bar" = "Paskatieties augšup. Cutling atrodas jūsu izvēļņu joslā";
"The clipboard icon at the top of your screen opens Cutling any time. Click it to see your saved cutlings and recent clipboard history." = "Starpliktuves ikona ekrāna augšpusē jebkurā brīdī atver Cutling. Noklikšķiniet uz tās, lai redzētu saglabātos Cutlingus un neseno starpliktuves vēsturi.";
"Summon Cutling from anywhere" = "Izsauciet Cutling no jebkuras vietas";
"Press ⌘⇧V from any app to open a floating picker at your cursor. Pick a cutling and it's ready to paste, no menu bar trip required." = "Nospiediet ⌘⇧V jebkurā lietotnē, lai pie kursora atvērtu peldošu atlasītāju. Izvēlieties Cutling, un tas ir gatavs ielīmēšanai, bez nepieciešamības doties uz izvēļņu joslu.";
"Rebind it later in Settings → Hotkey." = "Vēlāk mainiet to sadaļā Iestatījumi → Īsinājumtaustiņš.";
"Almost there" = "Gandrīz gatavs";
"You're all set" = "Viss ir gatavs";
"Two quick permissions so Cutling can work the way you'd expect. You can change either later in Settings." = "Divas ātras atļaujas, lai Cutling darbotos tā, kā gaidāt. Abas varat mainīt vēlāk Iestatījumos.";
"Launch at login" = "Palaist pieteikšanās brīdī";
"Open Cutling automatically when you sign in." = "Automātiski atvērt Cutling, kad piesakāties.";
"Accessibility access" = "Pieejamības piekļuve";
"Granted. Cutling can paste directly into other apps." = "Piešķirta. Cutling var ielīmēt tieši citās lietotnēs.";
"Lets Cutling paste a cutling straight into the app you were using." = "Ļauj Cutling ielīmēt Cutling tieši lietotnē, kuru izmantojāt.";
"Grant" = "Piešķirt";
"You can skip Accessibility and grant it later from Settings → Paste." = "Varat izlaist Pieejamību un piešķirt to vēlāk sadaļā Iestatījumi → Ielīmēt.";


/* MARK: - Image Saving (macOS) */
"Save as File…" = "Saglabāt kā failu…";
"Image Saving" = "Attēlu saglabāšana";
"When saving images" = "Saglabājot attēlus";
"Ask each time" = "Vaicāt katru reizi";
"Save to folder" = "Saglabāt mapē";
"Folder" = "Mape";
"Change Folder…" = "Mainīt mapi…";
"Choose how the “Save as File” action works for image cutlings. With “Save to folder”, images go straight into the folder you pick with a unique filename, no prompt." = "Izvēlies, kā darbība „Saglabāt kā failu“ darbojas attēlu Cutling vienībām. Ar „Saglabāt mapē“ attēli tiek saglabāti tieši izvēlētajā mapē ar unikālu faila nosaukumu, bez vaicāšanas.";
"Choose" = "Izvēlēties";
"Choose Image Folder" = "Izvēlēties attēlu mapi";
"Pick a folder where Cutling will save image cutlings." = "Izvēlies mapi, kurā Cutling saglabās attēlu Cutling vienības.";
"Preview" = "Priekšskatījums";


