"Add text to ${applicationName}" = "Føj tekst til ${applicationName}";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "Hent tekst af ${target} fra ${applicationName}";
"Read ${target} from ${applicationName}" = "Læs ${target} fra ${applicationName}";

