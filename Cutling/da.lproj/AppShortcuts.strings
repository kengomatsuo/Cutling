/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "Gem udklipsholder i ${applicationName}";
"Save to ${applicationName}" = "Gem i ${applicationName}";
"Add clipboard to ${applicationName}" = "Føj udklipsholder til ${applicationName}";
"Clip with ${applicationName}" = "Klip med ${applicationName}";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "Kopier ${target} fra ${applicationName}";
"Paste ${target} with ${applicationName}" = "Indsæt ${target} med ${applicationName}";
"Get ${target} from ${applicationName}" = "Hent ${target} fra ${applicationName}";

/* 3. Save Text */
"Save text to ${applicationName}" = "Gem tekst i ${applicationName}";
