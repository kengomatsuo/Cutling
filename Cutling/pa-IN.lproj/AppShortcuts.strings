/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "ਕਲਿੱਪਬੋਰਡ ਨੂੰ ${applicationName} ਵਿੱਚ ਸੰਭਾਲੋ";
"Save to ${applicationName}" = "${applicationName} ਵਿੱਚ ਸੰਭਾਲੋ";
"Add clipboard to ${applicationName}" = "ਕਲਿੱਪਬੋਰਡ ਨੂੰ ${applicationName} ਵਿੱਚ ਜੋੜੋ";
"Clip with ${applicationName}" = "${applicationName} ਨਾਲ ਕਲਿੱਪ ਕਰੋ";

/* 2. Copy Cutling */
