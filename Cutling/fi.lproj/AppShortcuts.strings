"Create image in ${applicationName}" = "Luo kuva sovelluksessa ${applicationName}";
"New image cutling with ${applicationName}" = "Uusi kuva-cutling sovelluksella ${applicationName}";

/* 8. Save Image */
"Save image to ${applicationName}" = "Tallenna kuva sovellukseen ${applicationName}";
"Save image with ${applicationName}" = "Tallenna kuva sovelluksella ${applicationName}";
"Add image to ${applicationName}" = "Lisää kuva sovellukseen ${applicationName}";

/* 9. Search Cutlings */
"Search ${applicationName}" = "Hae sovelluksesta ${applicationName}";
"Find in ${applicationName}" = "Etsi sovelluksesta ${applicationName}";
"Search in ${applicationName}" = "Hae sovelluksessa ${applicationName}";

