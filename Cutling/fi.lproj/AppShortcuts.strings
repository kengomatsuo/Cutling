/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "Tallenna leikepöytä sovellukseen ${applicationName}";
"Save to ${applicationName}" = "Tallenna sovellukseen ${applicationName}";
"Add clipboard to ${applicationName}" = "Lisää leikepöytä sovellukseen ${applicationName}";
"Clip with ${applicationName}" = "Leikkaa sovelluksella ${applicationName}";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "Kopioi ${target} sovelluksesta ${applicationName}";
"Paste ${target} with ${applicationName}" = "Liitä ${target} sovelluksella ${applicationName}";
"Get ${target} from ${applicationName}" = "Hae ${target} sovelluksesta ${applicationName}";

/* 3. Save Text */
"Save text to ${applicationName}" = "Tallenna teksti sovellukseen ${applicationName}";
"Save text with ${applicationName}" = "Tallenna teksti sovelluksella ${applicationName}";
"Add text to ${applicationName}" = "Lisää teksti sovellukseen ${applicationName}";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "Hae ${target} teksti sovelluksesta ${applicationName}";
"Read ${target} from ${applicationName}" = "Lue ${target} sovelluksesta ${applicationName}";

/* 5. Latest Cutling */
"Get latest from ${applicationName}" = "Hae uusin sovelluksesta ${applicationName}";
"Latest ${applicationName}" = "Uusin ${applicationName}";
"Most recent ${applicationName}" = "Viimeisin ${applicationName}";

/* 6. New Text Cutling */
"New text in ${applicationName}" = "Uusi teksti sovelluksessa ${applicationName}";
"Create text in ${applicationName}" = "Luo teksti sovelluksessa ${applicationName}";
