/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "שמור לוח גזירים ב-${applicationName}";
"Save to ${applicationName}" = "שמור ב-${applicationName}";
"Add clipboard to ${applicationName}" = "הוסף לוח גזירים ל-${applicationName}";
"Clip with ${applicationName}" = "גזור עם ${applicationName}";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "העתק ${target} מ-${applicationName}";
"Paste ${target} with ${applicationName}" = "הדבק ${target} עם ${applicationName}";
"Get ${target} from ${applicationName}" = "קבל ${target} מ-${applicationName}";

/* 3. Save Text */
"Save text to ${applicationName}" = "שמור טקסט ב-${applicationName}";
"Save text with ${applicationName}" = "שמור טקסט עם ${applicationName}";
"Add text to ${applicationName}" = "הוסף טקסט ל-${applicationName}";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "קבל את הטקסט של ${target} מ-${applicationName}";
"Read ${target} from ${applicationName}" = "קרא ${target} מ-${applicationName}";

/* 5. Latest Cutling */
"Get latest from ${applicationName}" = "קבל את האחרון מ-${applicationName}";
"Latest ${applicationName}" = "${applicationName} אחרון";
"Most recent ${applicationName}" = "${applicationName} עדכני ביותר";

/* 6. New Text Cutling */
"New text in ${applicationName}" = "טקסט חדש ב-${applicationName}";
"Create text in ${applicationName}" = "צור טקסט ב-${applicationName}";
"New text cutling with ${applicationName}" = "קאטלינג טקסט חדש עם ${applicationName}";

/* 7. New Image Cutling */
"New image in ${applicationName}" = "תמונה חדשה ב-${applicationName}";
"Create image in ${applicationName}" = "צור תמונה ב-${applicationName}";
"New image cutling with ${applicationName}" = "קאטלינג תמונה חדש עם ${applicationName}";

/* 8. Save Image */
"Save image to ${applicationName}" = "שמור תמונה ב-${applicationName}";
"Save image with ${applicationName}" = "שמור תמונה עם ${applicationName}";
"Add image to ${applicationName}" = "הוסף תמונה ל-${applicationName}";

/* 9. Search Cutlings */
"Search ${applicationName}" = "חפש ב-${applicationName}";
"Find in ${applicationName}" = "מצא ב-${applicationName}";
"Search in ${applicationName}" = "חיפוש בתוך ${applicationName}";

/* 10. Open Cutling */
"Open ${applicationName}" = "פתח ${applicationName}";
"Launch ${applicationName}" = "הפעל ${applicationName}";
