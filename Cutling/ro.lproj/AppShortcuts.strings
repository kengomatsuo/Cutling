/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "Salvează clipboardul în ${applicationName}";
"Save to ${applicationName}" = "Salvează în ${applicationName}";
"Add clipboard to ${applicationName}" = "Adaugă clipboardul în ${applicationName}";
"Clip with ${applicationName}" = "Decupează cu ${applicationName}";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "Copiază ${target} din ${applicationName}";
"Paste ${target} with ${applicationName}" = "Lipește ${target} cu ${applicationName}";
"Get ${target} from ${applicationName}" = "Obține ${target} din ${applicationName}";

/* 3. Save Text */
"Save text to ${applicationName}" = "Salvează text în ${applicationName}";
"Save text with ${applicationName}" = "Salvează text cu ${applicationName}";
"Add text to ${applicationName}" = "Adaugă text în ${applicationName}";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "Obține textul ${target} din ${applicationName}";
"Read ${target} from ${applicationName}" = "Citește ${target} din ${applicationName}";

