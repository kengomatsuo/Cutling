/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "Guardar portapapeles en ${applicationName}";
"Save to ${applicationName}" = "Guardar en ${applicationName}";
"Add clipboard to ${applicationName}" = "Agregar portapapeles a ${applicationName}";
"Clip with ${applicationName}" = "Recortar con ${applicationName}";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "Copiar ${target} de ${applicationName}";
"Paste ${target} with ${applicationName}" = "Pegar ${target} con ${applicationName}";
"Get ${target} from ${applicationName}" = "Obtener ${target} de ${applicationName}";

/* 3. Save Text */
