"Hold any card for quick actions: copy, edit, share, or delete." = "I-hold ang anumang card para sa mabilis na aksyon: copy, edit, share, o delete.";
"Drag to select" = "I-drag para pumili";
"Swipe across cards to select a range. Swipe back over them to deselect." = "I-swipe sa mga card para pumili ng range. I-swipe pabalik para i-deselect.";
"Smart field matching" = "Smart field matching";
"Cutling spots email, URL, phone, and address fields, then floats matching snippets to the top of the keyboard." = "Tinutukoy ng Cutling ang mga email, URL, telepono, at address na field, at inaakyat ang tugmang snippet sa itaas ng keyboard.";
"Create a new cutling" = "Gumawa ng bagong cutling";
"Save text or image snippets you'll reuse from any app." = "Mag-save ng mga teksto o larawan na gagamitin mo ulit sa kahit anong app.";

/* MARK: - Welcome Window (macOS first launch) */
"Welcome to Cutling" = "Maligayang Pagdating sa Cutling";
"Your clipboard, organised." = "Ang iyong clipboard, maayos.";
"Save the snippets, images, and links you reuse. Capture everything you copy. Paste anywhere with one shortcut." = "I-save ang mga snippet, larawan, at link na ginagamit mo ulit. Makukuha ang lahat ng kinokopya mo. I-paste kahit saan gamit ang isang shortcut.";
"Look up. Cutling lives in your menu bar" = "Tumingin sa itaas. Nasa menu bar mo ang Cutling";
"The clipboard icon at the top of your screen opens Cutling any time. Click it to see your saved cutlings and recent clipboard history." = "Ang clipboard icon sa itaas ng iyong screen ang nagbubukas ng Cutling anumang oras. I-click ito para makita ang mga naka-save na cutling at kamakailang kasaysayan ng clipboard.";
"Summon Cutling from anywhere" = "Buksan ang Cutling kahit saan";
"Press ⌘⇧V from any app to open a floating picker at your cursor. Pick a cutling and it's ready to paste, no menu bar trip required." = "Pindutin ang ⌘⇧V mula sa kahit anong app para magbukas ng floating picker sa iyong cursor. Pumili ng cutling at handa nang i-paste, hindi na kailangang pumunta sa menu bar.";
"Rebind it later in Settings → Hotkey." = "Maaari mong baguhin ang shortcut sa Settings → Hotkey.";
"Almost there" = "Malapit na";
"You're all set" = "Handa ka na";
"Two quick permissions so Cutling can work the way you'd expect. You can change either later in Settings." = "Dalawang mabilisang permission para magamit ng tama ang Cutling. Pwede mong baguhin ang alinman sa Settings sa ibang pagkakataon.";
"Launch at login" = "Buksan kapag nag-sign in";
"Open Cutling automatically when you sign in." = "Awtomatikong magbukas ang Cutling kapag nag-sign in ka.";
"Accessibility access" = "Accessibility access";
"Granted. Cutling can paste directly into other apps." = "Naipagkaloob na. Maaaring direktang mag-paste ang Cutling sa ibang mga app.";
"Lets Cutling paste a cutling straight into the app you were using." = "Pinapayagan nito ang Cutling na mag-paste ng cutling diretso sa app na ginagamit mo.";
"Grant" = "Ipagkaloob";
"You can skip Accessibility and grant it later from Settings → Paste." = "Maaari mong laktawan ang Accessibility at ipagkaloob ito mamaya sa Settings → Paste.";


/* MARK: - Image Saving (macOS) */
"Save as File…" = "I-save bilang file…";
"Image Saving" = "Pag-save ng larawan";
"When saving images" = "Kapag nagse-save ng mga larawan";
"Ask each time" = "Magtanong sa bawat pagkakataon";
"Save to folder" = "I-save sa folder";
"Folder" = "Folder";
"Change Folder…" = "Palitan ang folder…";
"Choose how the “Save as File” action works for image cutlings. With “Save to folder”, images go straight into the folder you pick with a unique filename, no prompt." = "Piliin kung paano gumagana ang aksyong “I-save bilang file” para sa mga image cutling. Sa “I-save sa folder”, derecho mase-save ang mga larawan sa folder na iyong pinili na may natatanging pangalan ng file, nang walang tanong.";
"Choose" = "Piliin";
"Choose Image Folder" = "Pumili ng folder ng larawan";
"Pick a folder where Cutling will save image cutlings." = "Pumili ng folder kung saan ise-save ng Cutling ang mga image cutling.";
"Preview" = "Preview";


/* MARK: - Newly added keys */
"Saved" = "Nai-save";
"History" = "Kasaysayan";
"No saved cutlings yet" = "Wala pang naka-save na cutling";
"Copy something to see it here" = "Mag-copy ng kahit ano para makita rito";
"Clipboard history is off. Enable it in Settings." = "Naka-off ang kasaysayan ng clipboard. I-on sa Settings.";
"Spotlight" = "Spotlight";
"Include in Spotlight Search" = "Isama sa paghahanap sa Spotlight";
"Make your cutlings searchable from Spotlight. Sensitive content (credit cards, API keys, JWT tokens, seed phrases, private keys) is never indexed." = "Gawing mahahanap ang iyong mga cutling sa Spotlight. Ang sensitibong nilalaman (credit cards, API keys, JWT tokens, seed phrases, private keys) ay hindi kailanman ini-index.";
"Copy Cutling" = "Kopyahin ang Cutling";
"Copy a cutling's contents to the clipboard." = "Kinokopya ang nilalaman ng cutling sa clipboard.";
"Use these phrases with Siri or browse all Cutling shortcuts in the Shortcuts app." = "Gamitin ang mga pariralang ito sa Siri o tingnan ang lahat ng Cutling shortcut sa Shortcuts app.";
"Copied \"%@\"" = "Na-copy ang “%@”";

/* MARK: - Paste Settings (macOS) - Direct Paste opt-in */
"Paste directly into other apps" = "I-paste nang direkta sa ibang apps";
"When on, picking a cutling from the hotkey-summoned picker sends a single ⌘V keystroke into the app that was frontmost, so the cutling is pasted at the cursor. Off by default. When off, Cutling copies to the clipboard and you paste manually with ⌘V." = "Kapag naka-on, ang pagpili ng cutling mula sa picker na binubuksan ng hotkey ay nagpapadala ng isang ⌘V keystroke sa app na nasa harapan, kaya ang cutling ay napa-paste sa cursor. Naka-off bilang default. Kapag naka-off, kinokopya ng Cutling sa clipboard at ipa-paste mo nang manual gamit ang ⌘V.";
"Permission" = "Pahintulot";
"Cutling uses Accessibility access only to send the ⌘V keystroke to the previously focused app after you pick a cutling. It does not read other apps' UI or control your computer." = "Gumagamit lamang ang Cutling ng Accessibility access para magpadala ng ⌘V keystroke sa app na huling nakatuon pagkatapos mong pumili ng cutling. Hindi nito binabasa ang UI ng ibang apps o kinokontrol ang iyong computer.";
"Direct Paste" = "Direktang Pag-paste";
"Direct paste needs Accessibility access." = "Ang direktang pag-paste ay nangangailangan ng Accessibility access.";
