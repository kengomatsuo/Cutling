/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "Spremi međuspremnik u ${applicationName}";
"Save to ${applicationName}" = "Spremi u ${applicationName}";
"Add clipboard to ${applicationName}" = "Dodaj međuspremnik u ${applicationName}";
"Clip with ${applicationName}" = "Izreži s ${applicationName}";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "Kopiraj ${target} iz ${applicationName}";
"Paste ${target} with ${applicationName}" = "Zalijepi ${target} pomoću ${applicationName}";
"Get ${target} from ${applicationName}" = "Dohvati ${target} iz ${applicationName}";

/* 3. Save Text */
"Save text to ${applicationName}" = "Spremi tekst u ${applicationName}";
"Save text with ${applicationName}" = "Spremi tekst pomoću ${applicationName}";
"Add text to ${applicationName}" = "Dodaj tekst u ${applicationName}";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "Dohvati tekst od ${target} iz ${applicationName}";
"Read ${target} from ${applicationName}" = "Pročitaj ${target} iz ${applicationName}";

/* 5. Latest Cutling */
"Get latest from ${applicationName}" = "Dohvati posljednje iz ${applicationName}";
