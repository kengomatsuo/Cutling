/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "Vágólap mentése ide: ${applicationName}";
"Save to ${applicationName}" = "Mentés ide: ${applicationName}";
"Add clipboard to ${applicationName}" = "Vágólap hozzáadása a ${applicationName} alkalmazáshoz";
"Clip with ${applicationName}" = "Kivágás a ${applicationName} alkalmazással";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "${target} másolása innen: ${applicationName}";
"Paste ${target} with ${applicationName}" = "${target} beillesztése a ${applicationName} alkalmazással";
"Get ${target} from ${applicationName}" = "${target} lekérése innen: ${applicationName}";

/* 3. Save Text */
"Save text to ${applicationName}" = "Szöveg mentése ide: ${applicationName}";
"Save text with ${applicationName}" = "Szöveg mentése a ${applicationName} alkalmazással";
"Add text to ${applicationName}" = "Szöveg hozzáadása a ${applicationName} alkalmazáshoz";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "${target} szövegének lekérése innen: ${applicationName}";
"Read ${target} from ${applicationName}" = "${target} olvasása innen: ${applicationName}";

/* 5. Latest Cutling */
"Get latest from ${applicationName}" = "Legutóbbi lekérése innen: ${applicationName}";
"Latest ${applicationName}" = "Legutóbbi ${applicationName}";
"Most recent ${applicationName}" = "Legújabb ${applicationName}";

/* 6. New Text Cutling */
"New text in ${applicationName}" = "Új szöveg a ${applicationName} alkalmazásban";
"Create text in ${applicationName}" = "Szöveg létrehozása a ${applicationName} alkalmazásban";
"New text cutling with ${applicationName}" = "Új szöveges Cutling a ${applicationName} alkalmazással";

/* 7. New Image Cutling */
"New image in ${applicationName}" = "Új kép a ${applicationName} alkalmazásban";
"Create image in ${applicationName}" = "Kép létrehozása a ${applicationName} alkalmazásban";
"New image cutling with ${applicationName}" = "Új képes Cutling a ${applicationName} alkalmazással";

/* 8. Save Image */
"Save image to ${applicationName}" = "Kép mentése ide: ${applicationName}";
"Save image with ${applicationName}" = "Kép mentése a ${applicationName} alkalmazással";
"Add image to ${applicationName}" = "Kép hozzáadása a ${applicationName} alkalmazáshoz";

/* 9. Search Cutlings */
"Search ${applicationName}" = "Keresés: ${applicationName}";
"Find in ${applicationName}" = "Keresés a ${applicationName} alkalmazásban";
"Search in ${applicationName}" = "Keresés a ${applicationName} alkalmazáson belül";

/* 10. Open Cutling */
"Open ${applicationName}" = "${applicationName} megnyitása";
"Launch ${applicationName}" = "${applicationName} elindítása";
