/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "클립보드를 ${applicationName}에 저장";
"Save to ${applicationName}" = "${applicationName}에 저장";
"Add clipboard to ${applicationName}" = "클립보드를 ${applicationName}에 추가";
"Clip with ${applicationName}" = "${applicationName}으로 클립";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "${applicationName}에서 ${target} 복사";
"Paste ${target} with ${applicationName}" = "${applicationName}으로 ${target} 붙여넣기";
"Get ${target} from ${applicationName}" = "${applicationName}에서 ${target} 가져오기";

/* 3. Save Text */
"Save text to ${applicationName}" = "텍스트를 ${applicationName}에 저장";
"Save text with ${applicationName}" = "${applicationName}으로 텍스트 저장";
"Add text to ${applicationName}" = "텍스트를 ${applicationName}에 추가";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "${applicationName}에서 ${target}의 텍스트 가져오기";
"Read ${target} from ${applicationName}" = "${applicationName}에서 ${target} 읽기";

/* 5. Latest Cutling */
"Get latest from ${applicationName}" = "${applicationName}에서 최근 항목 가져오기";
"Latest ${applicationName}" = "최근 ${applicationName}";
"Most recent ${applicationName}" = "가장 최근 ${applicationName}";

/* 6. New Text Cutling */
"New text in ${applicationName}" = "${applicationName}에서 새 텍스트";
"Create text in ${applicationName}" = "${applicationName}에서 텍스트 생성";
"New text cutling with ${applicationName}" = "${applicationName}으로 새 텍스트 컷링";

/* 7. New Image Cutling */
"New image in ${applicationName}" = "${applicationName}에서 새 이미지";
"Create image in ${applicationName}" = "${applicationName}에서 이미지 생성";
"New image cutling with ${applicationName}" = "${applicationName}으로 새 이미지 컷링";

/* 8. Save Image */
"Save image to ${applicationName}" = "이미지를 ${applicationName}에 저장";
"Save image with ${applicationName}" = "${applicationName}으로 이미지 저장";
"Add image to ${applicationName}" = "이미지를 ${applicationName}에 추가";

/* 9. Search Cutlings */
"Search ${applicationName}" = "${applicationName} 검색";
"Find in ${applicationName}" = "${applicationName}에서 찾기";
"Search in ${applicationName}" = "${applicationName} 안에서 검색";

/* 10. Open Cutling */
"Open ${applicationName}" = "${applicationName} 열기";
"Launch ${applicationName}" = "${applicationName} 실행";
