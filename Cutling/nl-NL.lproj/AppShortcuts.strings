/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "Klembord opslaan in ${applicationName}";
"Save to ${applicationName}" = "Opslaan in ${applicationName}";
"Add clipboard to ${applicationName}" = "Klembord toevoegen aan ${applicationName}";
"Clip with ${applicationName}" = "Knippen met ${applicationName}";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "${target} kopiëren vanuit ${applicationName}";
"Paste ${target} with ${applicationName}" = "${target} plakken met ${applicationName}";
"Get ${target} from ${applicationName}" = "${target} ophalen uit ${applicationName}";

/* 3. Save Text */
"Save text to ${applicationName}" = "Tekst opslaan in ${applicationName}";
"Save text with ${applicationName}" = "Tekst opslaan met ${applicationName}";
"Add text to ${applicationName}" = "Tekst toevoegen aan ${applicationName}";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "Tekst van ${target} ophalen uit ${applicationName}";
"Read ${target} from ${applicationName}" = "${target} lezen uit ${applicationName}";

