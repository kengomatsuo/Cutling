/* App Shortcut phrases. Keys MUST match the exact English phrases in
   CutlingAppShortcutsProvider.swift. The ${applicationName} placeholder
   is required in every phrase. ${target} maps to the AppEntity parameter. */

/* 1. Save Clipboard */
"Save clipboard to ${applicationName}" = "Guardar área de transferência em ${applicationName}";
"Save to ${applicationName}" = "Guardar em ${applicationName}";
"Add clipboard to ${applicationName}" = "Adicionar área de transferência a ${applicationName}";
"Clip with ${applicationName}" = "Recortar com ${applicationName}";

/* 2. Copy Cutling */
"Copy ${target} from ${applicationName}" = "Copiar ${target} de ${applicationName}";
"Paste ${target} with ${applicationName}" = "Colar ${target} com ${applicationName}";
"Get ${target} from ${applicationName}" = "Obter ${target} de ${applicationName}";

/* 3. Save Text */
"Save text to ${applicationName}" = "Guardar texto em ${applicationName}";
"Save text with ${applicationName}" = "Guardar texto com ${applicationName}";
"Add text to ${applicationName}" = "Adicionar texto a ${applicationName}";

/* 4. Get Cutling Text */
"Get text of ${target} from ${applicationName}" = "Obter texto de ${target} de ${applicationName}";
"Read ${target} from ${applicationName}" = "Ler ${target} de ${applicationName}";

/* 5. Latest Cutling */
"Get latest from ${applicationName}" = "Obter o último de ${applicationName}";
"Latest ${applicationName}" = "Último ${applicationName}";
"Most recent ${applicationName}" = "${applicationName} mais recente";

/* 6. New Text Cutling */
"New text in ${applicationName}" = "Novo texto em ${applicationName}";
"Create text in ${applicationName}" = "Criar texto em ${applicationName}";
"New text cutling with ${applicationName}" = "Novo cutling de texto com ${applicationName}";

/* 7. New Image Cutling */
"New image in ${applicationName}" = "Nova imagem em ${applicationName}";
"Create image in ${applicationName}" = "Criar imagem em ${applicationName}";
"New image cutling with ${applicationName}" = "Novo cutling de imagem com ${applicationName}";

/* 8. Save Image */
"Save image to ${applicationName}" = "Guardar imagem em ${applicationName}";
"Save image with ${applicationName}" = "Guardar imagem com ${applicationName}";
"Add image to ${applicationName}" = "Adicionar imagem a ${applicationName}";

/* 9. Search Cutlings */
"Search ${applicationName}" = "Pesquisar ${applicationName}";
"Find in ${applicationName}" = "Encontrar em ${applicationName}";
"Search in ${applicationName}" = "Pesquisar em ${applicationName}";

/* 10. Open Cutling */
"Open ${applicationName}" = "Abrir ${applicationName}";
"Launch ${applicationName}" = "Iniciar ${applicationName}";
