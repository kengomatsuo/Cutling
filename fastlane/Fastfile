# Ensure Homebrew binaries (ImageMagick, etc.) are in PATH.
ENV["PATH"] = "/opt/homebrew/bin:#{ENV['PATH']}"

# Use locales.json as the single source of truth for ASC locale codes.
require 'json'
require 'fastlane_core/languages'

def locale_codes_from_json
  @locale_codes_from_json ||= JSON.parse(
    File.read(File.join(__dir__, '..', 'locales.json'), encoding: 'UTF-8')
  ).map { |locale| locale.fetch('code') }
end

def localized_support_url(locale)
  "https://kengomatsuo.github.io/Cutling/#{locale.downcase}/support"
end

def localized_marketing_url(locale)
  "https://kengomatsuo.github.io/Cutling/#{locale.downcase}"
end

def read_metadata_text(file)
  return nil unless File.exist?(file)

  value = File.read(file, encoding: 'UTF-8').strip
  value.empty? ? nil : value
end

def ensure_locale_url_files
  metadata_path = File.join(__dir__, "metadata")

  locale_codes_from_json.each do |locale|
    locale_dir = File.join(metadata_path, locale)
    next unless File.directory?(locale_dir)

    support_url_file = File.join(locale_dir, "support_url.txt")
    marketing_url_file = File.join(locale_dir, "marketing_url.txt")

    support_url = read_metadata_text(support_url_file) || localized_support_url(locale)
    marketing_url = read_metadata_text(marketing_url_file) || localized_marketing_url(locale)

    File.write(support_url_file, "#{support_url}\n", mode: "w") unless File.exist?(support_url_file) && read_metadata_text(support_url_file)
    File.write(marketing_url_file, "#{marketing_url}\n", mode: "w") unless File.exist?(marketing_url_file) && read_metadata_text(marketing_url_file)
  end
end

BASE_FASTLANE_LOCALES = FastlaneCore::Languages::ALL_LANGUAGES.dup.freeze
locale_codes_from_json.each do |locale|
  FastlaneCore::Languages::ALL_LANGUAGES << locale unless FastlaneCore::Languages::ALL_LANGUAGES.include?(locale)
end

# Force UTF-8 locale — xcodebuild on iOS 26 emits UTF-16/non-ASCII output
# that crashes Ruby when the locale defaults to US-ASCII.
ENV["LANG"]   = "en_US.UTF-8"
ENV["LC_ALL"] = "en_US.UTF-8"

# Monkey-patch: xcodebuild on iOS 26 emits UTF-16 bytes that crash Ruby's
# string operations inside fastlane's CommandExecutor PTY loop. Wrap the PTY
# stdout so every line is forced to valid UTF-8 before any processing.
require 'fastlane_core/fastlane_pty'

class UTF8SafeIO
  def initialize(io)
    @io = io
    # Read as raw bytes — let us handle encoding, not Ruby's IO layer
    @io.set_encoding('BINARY') if @io.respond_to?(:set_encoding)
  end

  def each
    @io.each do |raw_line|
      yield raw_line.force_encoding('BINARY')
                     .encode('UTF-8', invalid: :replace, undef: :replace, replace: '')
    end
  rescue Encoding::InvalidByteSequenceError
    # Gracefully stop if IO-level encoding error slips through
  end

  def close
    @io.close unless @io.closed?
  end

  def method_missing(m, *args, &block)
    @io.send(m, *args, &block)
  end

  def respond_to_missing?(m, priv = false)
    @io.respond_to?(m, priv) || super
  end
end

::FastlaneCore::FastlanePty.class_eval do
  class << self
    alias_method :__orig_spawn_pty,   :spawn_with_pty
    alias_method :__orig_spawn_popen, :spawn_with_popen

    def spawn_with_pty(command, &block)
      __orig_spawn_pty(command) do |stdout, stdin, pid|
        yield(UTF8SafeIO.new(stdout), stdin, pid)
      end
    end

    def spawn_with_popen(command, &block)
      __orig_spawn_popen(command) do |stdout, stdin, pid|
        yield(UTF8SafeIO.new(stdout), stdin, pid)
      end
    end
  end
end

# Monkey-patch: simctl list devices reports truncated runtime versions
# (e.g. "26.4") but xcodebuild uses the full version ("26.4.1"), causing
# destination mismatches. Correct using fastlane's own runtime version data.
require 'fastlane_core/device_manager'
::FastlaneCore::DeviceManager.class_eval do
  class << self
    alias_method :__orig_simulators, :simulators
    def simulators(requested_os_type = "")
      devices = __orig_simulators(requested_os_type)
      actual = runtime_build_os_versions.values
      devices.each do |d|
        full = actual.find { |v| v != d.os_version && v.start_with?("#{d.os_version}.") }
        next unless full
        d.os_version = full
        d.ios_version = full
      end
      devices
    end
  end
end

# Monkey-patch: fastlane 2.232.2 calls device.devicetype.name but simctl gem
# may return a raw String when the devicetype lookup fails, crashing snapshot.
require "simctl"
::SimCtl::Device.class_eval do
  alias_method :original_devicetype, :devicetype
  define_method(:devicetype) do
    dt = original_devicetype
    return dt if dt.respond_to?(:name)
    Struct.new(:name).new(dt.to_s.split(".").last.gsub("-", " "))
  end
end


default_platform(:ios)

platform :ios do
  desc "Take localized screenshots"
  lane :screenshots do
    snapshot
  end

  desc "Take screenshots and add device frames with marketing text"
  lane :framed_screenshots do
    snapshot
    # Restore frameit assets that clear_previous_screenshots may have removed
    FileUtils.cp("./Framefile.json", "./screenshots/Framefile.json")
    FileUtils.cp("./background.png", "./screenshots/background.png")
    frameit(
      white: false,
      path: "./fastlane/screenshots"
    )
  end

  desc "Take screenshots for new ASC languages only (keeps existing screenshots)"
  lane :new_screenshots do
    locales = locale_codes_from_json
    screenshots_dir = File.join(__dir__, "screenshots")

    # Find ASC locales that don't have screenshots yet
    missing = locales
      .reject { |asc| Dir.glob(File.join(screenshots_dir, asc, "*.png")).any? }

    UI.message("Missing screenshots for: #{missing.join(', ')}")

    snapshot(
      languages: missing,
      clear_previous_screenshots: false,
      output_directory: "./fastlane/screenshots"
    )
  end

  desc "Frame screenshots with device bezels and marketing text"
  lane :frame do
    FileUtils.cp("./Framefile.json", "./screenshots/Framefile.json")
    FileUtils.cp("./background.png", "./screenshots/background.png")
    frameit(
      white: false,
      path: "./fastlane/screenshots"
    )
  end

  desc "Upload metadata only (no screenshots)"
  lane :upload_metadata do
    ensure_locale_url_files
    add_new_locales

    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      ignore_language_directory_validation: true
    )
  end

  desc "Upload screenshots only to App Store Connect"
  lane :upload_screenshots do
    Dir.glob(File.join(__dir__, "screenshots/**/*_framed.png")).each { |f| File.delete(f) }
    deliver(
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      force: true
    )
  end

  desc "Upload metadata and screenshots to App Store Connect"
  lane :upload do
    Dir.glob(File.join(__dir__, "screenshots/**/*_framed.png")).each { |f| File.delete(f) }
    ensure_locale_url_files
    add_new_locales

    deliver(
      skip_binary_upload: true,
      force: true
    )
  end

  desc "Create/update ASC localizations for new languages via Spaceship API"
  lane :add_new_locales do
    require 'spaceship'

    new_locales = locale_codes_from_json.reject { |locale| BASE_FASTLANE_LOCALES.include?(locale) }
    metadata_path = File.join(__dir__, "metadata")

    Spaceship::ConnectAPI.login(
      CredentialsManager::AppfileConfig.try_fetch_value(:apple_id),
      use_portal: false,
      use_tunes: true
    )

    app = Spaceship::ConnectAPI::App.find("com.matsuokengo.Cutling")
    UI.user_error!("App not found") unless app

    version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    UI.user_error!("No editable version found") unless version

    existing = version.get_app_store_version_localizations.map(&:locale)
    UI.message("Existing locales: #{existing.join(', ')}")

    new_locales.each do |locale|
      locale_dir = File.join(metadata_path, locale)
      next unless File.directory?(locale_dir)

      if existing.include?(locale)
        UI.message("Locale #{locale} already exists, updating...")
        loc = version.get_app_store_version_localizations.find { |l| l.locale == locale }
      else
        UI.message("Creating locale #{locale}...")
        begin
          loc = Spaceship::ConnectAPI.post_app_store_version_localization(
            app_store_version_id: version.id,
            attributes: { locale: locale }
          )
        rescue => e
          UI.error("Failed to create locale #{locale}: #{e.message}")
          next
        end
      end

      attrs = {}
      field_map = {
        "description" => "description",
        "keywords" => "keywords",
        "release_notes" => "whatsNew",
        "promotional_text" => "promotionalText"
      }
      field_map.each do |file_key, api_key|
        file = File.join(locale_dir, "#{file_key}.txt")
        value = read_metadata_text(file)
        attrs[api_key.to_sym] = value if value
      end

      attrs[:supportUrl] = read_metadata_text(File.join(locale_dir, "support_url.txt")) || localized_support_url(locale)
      attrs[:marketingUrl] = read_metadata_text(File.join(locale_dir, "marketing_url.txt")) || localized_marketing_url(locale)

      begin
        loc_obj = loc.is_a?(Spaceship::ConnectAPI::Response) ? loc.to_models.first : loc
        Spaceship::ConnectAPI.patch_app_store_version_localization(
          app_store_version_localization_id: loc_obj.id,
          attributes: attrs
        )
        UI.success("Updated metadata for #{locale}")
      rescue => e
        UI.error("Failed to update #{locale}: #{e.message}")
      end
    end

    app_info = app.fetch_edit_app_info
    if app_info
      existing_info = app_info.get_app_info_localizations.map(&:locale)

      new_locales.each do |locale|
        locale_dir = File.join(metadata_path, locale)
        next unless File.directory?(locale_dir)

        unless existing_info.include?(locale)
          begin
            Spaceship::ConnectAPI.post_app_info_localization(
              app_info_id: app_info.id,
              attributes: { locale: locale }
            )
          rescue => e
            UI.error("Failed to create app info locale #{locale}: #{e.message}")
            next
          end
        end

        info_loc = app_info.get_app_info_localizations.find { |l| l.locale == locale }
        next unless info_loc

        attrs = {}
        name_file = File.join(locale_dir, "name.txt")
        subtitle_file = File.join(locale_dir, "subtitle.txt")

        attrs[:name] = read_metadata_text(name_file) if File.exist?(name_file)
        attrs[:subtitle] = read_metadata_text(subtitle_file) if File.exist?(subtitle_file)

        begin
          Spaceship::ConnectAPI.patch_app_info_localization(
            app_info_localization_id: info_loc.id,
            attributes: attrs
          )
          UI.success("Updated app info for #{locale}")
        rescue => e
          UI.error("Failed to update app info #{locale}: #{e.message}")
        end
      end
    end
  end

  desc "Build IPA for App Store submission"
  lane :build do
    gym(
      scheme: "Cutling",
      export_method: "app-store",
      output_directory: "./build",
      clean: true
    )
  end

  desc "Full deploy: metadata → missing screenshots → frame → upload all → build & submit"
  lane :deploy do
    # 1. Upload metadata (standard + new locales)
    UI.header("Step 1/5: Uploading metadata")
    upload_metadata

    # 2. Capture missing screenshots
    UI.header("Step 2/5: Capturing missing screenshots")
    new_screenshots

    # 3. Frame screenshots
    UI.header("Step 3/5: Framing screenshots")
    frame

    # 4. Upload screenshots
    UI.header("Step 4/5: Uploading screenshots")
    upload_screenshots

    # 5. Build and upload binary
    UI.header("Step 5/5: Building and uploading binary")
    build
    deliver(
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      ipa: "./build/Cutling.ipa"
    )

    UI.success("Deploy complete!")
  end
end
